# .agentignore — Files the AI agent must NEVER read
# These are built artifacts, minified bundles, and binary assets.
# Reading them wastes 55,000–280,000 tokens with zero useful signal.

# ============================================================
# BUILT BUNDLES (auto-generated by webpack — never edit directly)
# ============================================================
appserver/static/visualizations/AWS-DFD-Visualizer/visualization.js
appserver/static/visualizations/AWS-DFD-Visualizer/d3.v7.min.js
appserver/static/visualizations/AWS-DFD-Visualizer/index.js
appserver/static/visualizations/AWS-DFD-Visualizer/visualization.js.LICENSE.txt
src/main/webapp/

# ============================================================
# BINARY / MEDIA ASSETS (images, icons — not readable as text)
# ============================================================
appserver/static/icons/
appserver/static/*.png
appserver/static/logo.png
appserver/static/logo_2x.png
appserver/static/appIcon.png
appserver/static/appIcon_2x.png
appserver/static/visualizations/AWS-DFD-Visualizer/preview.png
*.png
*.webp
*.jpg
*.jpeg

# ============================================================
# DEPENDENCY TREE (too large, use package.json instead)
# ============================================================
node_modules/
package-lock.json
dist/

# ============================================================
# STALE / REDUNDANT DOCS (fully replaced by .agents/rules/)
# ============================================================
lesson_gh_preference.md
lessons_learned_splunk_viz.md
