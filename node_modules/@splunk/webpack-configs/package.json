{
  "name": "@splunk/webpack-configs",
  "version": "7.0.3",
  "description": "Standardized webpack configuration files for apps and components",
  "license": "Apache-2.0",
  "author": "Splunk Inc.",
  "main": "base.config.js",
  "scripts": {
    "build": "babel src -d . --ignore \"**/docs\"",
    "docs": "NODE_ENV=production webpack --config docs.gen.webpack.config.js",
    "docs:publish": "eval $(splunk-docs-package docs) && artifact-ci publish generic $DOCS_GEN_OUTPUT_NAME $DOCS_GEN_REMOTE_PATH",
    "docs:publish:external": "eval $(splunk-docs-package docs-external --suffix=public) && artifact-ci publish generic $DOCS_GEN_OUTPUT_NAME $DOCS_GEN_REMOTE_PATH",
    "docs:start": "webpack serve --config docs.gen.webpack.config.js",
    "lint": "eslint src",
    "lint:ci": "yarn run lint -- -f junit -o test-reports/lint-results.xml",
    "start": "yarn run babel --watch"
  },
  "dependencies": {
    "imports-loader": "^4.0.1",
    "terser-webpack-plugin": "^5.3.9",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-merge": "^5.9.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.0",
    "@babel/core": "^7.28.0",
    "@splunk/babel-preset": "^4.0.0",
    "@splunk/eslint-config": "^5.0.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-webpack": "^0.13.4",
    "eslint-plugin-import": "^2.30.1",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.36.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.2"
  },
  "peerDependencies": {
    "@babel/core": "^7",
    "@splunk/dashboard-extension-webpack-plugin": "^3.0.1",
    "babel-loader": "^8",
    "webpack": "^5"
  },
  "engines": {
    "node": ">=14"
  }
}
