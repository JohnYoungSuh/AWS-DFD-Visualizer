{
  "name": "aws-dfd-visualizer",
  "version": "2.8.0",
  "description": "Interactive AWS Data Flow Diagrams (DFD) for Splunk. Visualizes AWS Config topologies, nested VPCs/Subnets, and Zero-Trust compliance highlights.",
  "main": "src/visualization_source.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "webpack --mode production",
    "start": "webpack --mode development --watch",
    "test:cy": "cypress run --component"
  },
  "dependencies": {
    "@splunk/react-ui": "^5.9.0",
    "@splunk/themes": "^1.6.0",
    "d3": "^7.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/preset-react": "^7.18.6",
    "@cypress/react18": "^2.0.1",
    "@splunk/webpack-configs": "latest",
    "babel-loader": "^8.4.1",
    "cypress": "^15.14.2",
    "webpack": "^5.93.0",
    "webpack-cli": "^5.0.0",
    "webpack-dev-server": "^5.2.3"
  }
}
